# =============================================================================
# World Cup 2026 Ticket Bot — environment variables
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
# =============================================================================


# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
# Use a strong random string — e.g.: openssl rand -hex 32
POSTGRES_PASSWORD=change_me


# ---------------------------------------------------------------------------
# Gmail SMTP  (shared credentials for email-to-SMS delivery)
# ---------------------------------------------------------------------------
GMAIL_USER=you@gmail.com

# 16-character App Password (NOT your real Gmail password).
# Create one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on the account.)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx


# ---------------------------------------------------------------------------
# Alert contacts  (comma-separated PHONE:CARRIER pairs)
# ---------------------------------------------------------------------------
# Supported carriers: att, verizon, tmobile, sprint, cricket
# Example: 2125551234:verizon,6465559876:att
WORLDCUP_NOTIFY_PHONES=2125551234:verizon,6465559876:att


# ---------------------------------------------------------------------------
# Price thresholds per section tier (USD)
# An alert fires when the lowest available price for a game drops AT OR BELOW
# the matching threshold.  "any" section (API-only results) is checked against
# the upper_deck threshold as the conservative baseline.
# ---------------------------------------------------------------------------
WORLDCUP_PRICE_FIELD_LEVEL=500
WORLDCUP_PRICE_LOWER_BOWL=200
WORLDCUP_PRICE_UPPER_DECK=100


# ---------------------------------------------------------------------------
# Polling interval
# ---------------------------------------------------------------------------
# How often (in minutes) to poll all sites.  30 is a safe default that avoids
# looking like a bot while still catching most meaningful price drops.
WORLDCUP_POLL_INTERVAL_MINUTES=30


# ---------------------------------------------------------------------------
# Ticketmaster Discovery API  (free tier — no rate-limit concerns at 30 min)
# Register at: https://developer.ticketmaster.com/
# ---------------------------------------------------------------------------
TICKETMASTER_API_KEY=your_key_here


# ---------------------------------------------------------------------------
# SeatGeek API  (free tier)
# Register at: https://platform.seatgeek.com/
# ---------------------------------------------------------------------------
SEATGEEK_CLIENT_ID=your_id_here
SEATGEEK_CLIENT_SECRET=your_secret_here
